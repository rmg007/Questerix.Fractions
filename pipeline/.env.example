# LLM provider — pick one. Default is "anthropic".
LLM_PROVIDER=anthropic

# --- Provider: anthropic (default) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Provider: cloudflare (Workers AI) ---
# When LLM_PROVIDER=cloudflare, the pipeline calls Cloudflare Workers AI instead.
# Same content schema, same retry/parity logic. Build-time only — does not
# violate C1 (no runtime backend).
# CLOUDFLARE_API_TOKEN=...
# CLOUDFLARE_ACCOUNT_ID=...
# CLOUDFLARE_AI_GATEWAY=                       # optional gateway name for caching/observability
# CLOUDFLARE_MODEL=@cf/meta/llama-3.1-70b-instruct
