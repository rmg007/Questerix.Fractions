#!/usr/bin/env sh
# Quick pre-commit check — typecheck only (~3s).
# Heavy gates (lint, unit, integration, build, bundle) run on pre-push via
# scripts/preflight-router.mjs. Do NOT add work here — it slows every commit
# and an aborted commit loses the staged diff. Push-time is the right tier.
npm run typecheck

# CLAUDE.md drift check — regenerate auto-managed sections from
# .claude/agents/*.md and .claude/commands/*.md, then auto-stage if changes detected.
# This prevents drift from blocking commits.
npm run sync:claude-md
if ! git diff --exit-code CLAUDE.md >/dev/null 2>&1; then
  echo "ℹ CLAUDE.md drift detected — auto-fixing and re-staging." >&2
  git add CLAUDE.md
fi

# Auto-format staged .ts files — eliminates Prettier drift before push gate.
npx lint-staged
