{
  "name": "questerix-fractions",
  "version": "1.0.0",
  "type": "module",
  "description": "Phaser 4 + TypeScript educational game for K-2 fraction concepts. Validation-stage MVP.",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "dev:app": "vite",
    "build:curriculum": "node scripts/build-curriculum.mjs",
    "prebuild": "npm run build:curriculum",
    "build": "tsc && vite build",
    "gen:workflows": "node scripts/workflows/generator.mjs",
    "preview": "vite preview",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test --grep a11y",
    "typecheck": "tsc --noEmit",
    "build:analyze": "BUNDLE_ANALYZE=1 npm run build",
    "lint": "eslint src --max-warnings 0 && prettier --check src",
    "lint:fix": "eslint src --fix && prettier --write src",
    "lint:ci": "node scripts/residual-lint.mjs",
    "measure-bundle": "node scripts/measure-bundle.mjs",
    "deploy": "npx wrangler pages deploy dist --project-name questerix-fractions --branch main --commit-dirty=true",
    "validate:curriculum": "node scripts/validate-curriculum.mjs",
    "predeploy": "npm run typecheck && npm run lint && npm run test:unit && npm run validate:curriculum && npm run build && node scripts/measure-bundle.mjs",
    "postdeploy": "node scripts/postdeploy-check.mjs",
    "agent-doctor": "node scripts/agent-doctor.mjs",
    "sync:claude-md": "node scripts/sync-claude-md.mjs",
    "scaffold:scene": "node scripts/scaffold.mjs scene",
    "scaffold:validator": "node scripts/scaffold.mjs validator",
    "scaffold:component": "node scripts/scaffold.mjs component",
    "prepare": "husky"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.3",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "axe-core": "^4.10.0",
    "eslint": "^8.56.0",
    "fake-indexeddb": "^6.2.5",
    "fast-check": "^3.23.2",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "prettier": "^3.0.0",
    "rollup-plugin-visualizer": "^5.12.0",
    "tailwindcss": "^4.2.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vite-plugin-pwa": "^0.21.0",
    "vitest": "^1.0.0",
    "workbox-build": "^7.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "phaser",
    "typescript",
    "fractions",
    "educational",
    "game"
  ],
  "author": "Questerix Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/questerix/fractions"
  },
  "bugs": {
    "url": "https://github.com/questerix/fractions/issues"
  },
  "homepage": "https://questerix.app",
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/context-zone": "^2.7.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.216.0",
    "@opentelemetry/instrumentation": "^0.216.0",
    "@opentelemetry/instrumentation-fetch": "^0.216.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/sdk-trace-web": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@sentry/browser": "^10.51.0",
    "dexie": "^4.4.2",
    "phaser": "^4.0.0",
    "web-vitals": "^5.2.0",
    "workbox-window": "^7.4.0",
    "zod": "^4.4.1"
  }
}
